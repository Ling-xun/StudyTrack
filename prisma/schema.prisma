generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String    @default("#3B82F6")
  icon      String    @default("BookOpen")
  checkIns  CheckIn[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model CheckIn {
  id         String   @id @default(cuid())
  title      String
  content    String
  studyDate  DateTime
  duration   Int
  mood       String?
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AiSummary {
  id          String   @id @default(cuid())
  title       String
  content     String
  scopeType   String
  scopeValue  String?
  mode        String
  sourceCount Int      @default(0)
  sourceHash  String?
  model       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([mode, scopeType])
}

model AiConversation {
  id         String      @id @default(cuid())
  title      String
  scopeType  String?
  scopeValue String?
  mode       String?
  model      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  messages   AiMessage[]

  @@index([updatedAt])
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}
